# =============================================
# ThirdEye — Environment Configuration
# =============================================
# Copy this file to .env and fill in your values

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/thirdeye

# --- Twilio (SMS Alerts) ---
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15551234567
ALERT_PHONE_NUMBER=+15557654321

# --- Gmail (Email Alerts) ---
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
ALERT_EMAIL=youremail@gmail.com

# --- Search APIs ---
SHODAN_API_KEY=your_shodan_api_key
GNEWS_API_KEY=your_gnews_api_key
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
SERPAPI_KEY=your_serpapi_key

# --- App Config ---
SECRET_KEY=generate_a_random_64_char_string_here
ALERT_CONFIDENCE_THRESHOLD=0.75
LOG_CONFIDENCE_THRESHOLD=0.65
SCAN_INTERVAL_HOURS=6
CAM_SCAN_INTERVAL_MINUTES=10

# --- Radius Expansion Schedule (hours) ---
RADIUS_1MI_HOURS=6
RADIUS_5MI_HOURS=12
RADIUS_20MI_HOURS=24
RADIUS_CITY_DAYS=7
